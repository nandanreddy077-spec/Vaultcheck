// VaultCheck Prisma Schema
// Payment Verification for Accounting Firms

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Core Entities ───────────────────────────────────────────────────────────

model Firm {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  plan             String   @default("trial") // trial, solo, starter, growth, enterprise
  stripeCustomerId String?  @unique
  stripeSubId      String?
  maxClients       Int      @default(3)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users   User[]
  clients Client[]
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  role        String   @default("staff") // admin, staff, client_owner, client_viewer
  firmId      String
  supabaseUid String   @unique
  createdAt   DateTime @default(now())

  firm Firm @relation(fields: [firmId], references: [id])

  @@index([firmId])
}

model Client {
  id              String    @id @default(cuid())
  name            String
  firmId          String
  qboRealmId      String?   @unique
  qboAccessToken  String?
  qboRefreshToken String?
  qboTokenExpiry  DateTime?
  lastSyncAt      DateTime?
  syncStatus      String    @default("pending") // pending, syncing, synced, error
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  firm     Firm      @relation(fields: [firmId], references: [id])
  vendors  Vendor[]
  invoices Invoice[]
  alerts   Alert[]

  @@index([firmId])
}

// ─── Vendor & Fingerprint ────────────────────────────────────────────────────

model Vendor {
  id            String    @id @default(cuid())
  clientId      String
  qboVendorId   String
  displayName   String
  companyName   String?
  email         String?
  emailDomain   String?
  phone         String?
  bankAccount   String?
  routingNumber String?
  isActive      Boolean   @default(true)
  firstSeenAt   DateTime
  lastPaymentAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  client      Client             @relation(fields: [clientId], references: [id])
  fingerprint VendorFingerprint?
  invoices    Invoice[]

  @@unique([clientId, qboVendorId])
  @@index([clientId])
}

model VendorFingerprint {
  id                String   @id @default(cuid())
  vendorId          String   @unique
  avgAmount         Float
  stdDevAmount      Float
  minAmount         Float
  maxAmount         Float
  medianAmount      Float
  avgFreqDays       Float?
  typicalDayOfMonth Int[]
  knownEmails       String[]
  knownBankHashes   String[]
  invoicePatterns   String[]
  totalInvoices     Int
  totalPaid         Float
  confidenceScore   Float    @default(0)
  lastUpdated       DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id])
}

// ─── Invoice & Alert ─────────────────────────────────────────────────────────

model Invoice {
  id              String    @id @default(cuid())
  clientId        String
  vendorId        String?
  // QuickBooks Bill ID. Treated as unique so we can idempotently upsert during sync.
  qboBillId       String?  @unique
  invoiceNumber   String?
  amount          Float
  currency        String    @default("USD")
  dueDate         DateTime?
  senderEmail     String?
  bankAccountHash String?
  status          String    @default("pending") // pending, scanned, approved, rejected, paid
  riskScore       Int       @default(0)
  riskFactors     Json?
  scanResult      Json?
  scannedAt       DateTime?
  decidedAt       DateTime?
  decidedBy       String?
  createdAt       DateTime  @default(now())

  client Client  @relation(fields: [clientId], references: [id])
  vendor Vendor? @relation(fields: [vendorId], references: [id])
  alerts Alert[]

  @@index([clientId, status])
  @@index([vendorId])
  @@index([createdAt])
}

model Alert {
  id            String    @id @default(cuid())
  clientId      String
  invoiceId     String
  severity      String // critical, high, medium, low
  type          String // bank_change, amount_anomaly, new_vendor, email_mismatch, pattern_mismatch
  title         String
  description   String
  expectedValue String?
  actualValue   String?
  status        String    @default("open") // open, acknowledged, resolved, dismissed
  resolvedAt    DateTime?
  resolvedBy    String?
  resolution    String?
  createdAt     DateTime  @default(now())

  client  Client  @relation(fields: [clientId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([clientId, status])
  @@index([severity])
}

model AuditLog {
  id         String   @id @default(cuid())
  firmId     String
  clientId   String?
  userId     String?
  action     String
  entityType String
  entityId   String
  details    Json?
  createdAt  DateTime @default(now())

  @@index([firmId, createdAt])
  @@index([clientId, createdAt])
}
