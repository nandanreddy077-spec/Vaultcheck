# ── Supabase ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Database (Supabase PostgreSQL) ─────────────────────────────────────────────
# Get from Supabase → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── QuickBooks Online ──────────────────────────────────────────────────────────
# Get from developer.intuit.com → Your App → Keys & OAuth
QBO_CLIENT_ID=your-qbo-client-id
QBO_CLIENT_SECRET=your-qbo-client-secret
QBO_REDIRECT_URI=http://localhost:3000/api/qbo/callback
QBO_ENVIRONMENT=sandbox  # or production

# QuickBooks Webhooks
QBO_WEBHOOK_VERIFIER_TOKEN=your-qbo-webhook-verifier-token

# ── Encryption ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-hex-string-64-chars-total

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Stripe (Phase 3) ───────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_SOLO=price_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_GROWTH=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

# ── Resend (Phase 2 — email alerts) ────────────────────────────────────────────
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=alerts@vantirs.app

# ── Slack (Phase 3 — real-time alerts) ────────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Upstash Redis (Phase 3 — job queues) ───────────────────────────────────────
# UPSTASH_REDIS_URL=https://...
