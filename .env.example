# ── Supabase ───────────────────────────────────────────────────────────────────
# Use full URL with https:// (Vercel: avoid //project.supabase.co — the app normalizes it, but fixing env is best)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Database (Supabase PostgreSQL) ─────────────────────────────────────────────
# Get from Supabase → Settings → Database → Connection string (must start with postgresql:// — not //project.supabase.co or the REST API URL)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── QuickBooks Online ──────────────────────────────────────────────────────────
# Get from developer.intuit.com → Your App → Keys & OAuth
QBO_CLIENT_ID=your-qbo-client-id
QBO_CLIENT_SECRET=your-qbo-client-secret
QBO_REDIRECT_URI=http://localhost:3000/api/qbo/callback
QBO_ENVIRONMENT=sandbox  # or production

# QuickBooks Webhooks
QBO_WEBHOOK_VERIFIER_TOKEN=your-qbo-webhook-verifier-token

# ── Xero ──────────────────────────────────────────────────────────────────────
# Get from developer.xero.com → Your App → Configuration
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret
XERO_REDIRECT_URI=http://localhost:3000/api/xero/callback

# Xero Webhooks
XERO_WEBHOOK_KEY=your-xero-webhook-signing-key

# ── Encryption ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-hex-string-64-chars-total

# ── App ────────────────────────────────────────────────────────────────────────
# Local: http://localhost:3000 — Production: https://www.vantirs.com (used for SEO canonicals / sitemap)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Admin access control ───────────────────────────────────────────────────────
# Comma-separated list of emails allowed to access /admin routes.
ADMIN_EMAIL_ALLOWLIST=founder@vantirs.com

# ── Paddle Billing ─────────────────────────────────────────────────────────────
# Dashboard → Developer Tools → Authentication (API keys) and notification destinations (webhook secret)
# Catalog → each product → copy the recurring price ID (pri_...)
#
# PADDLE_API_KEY=pdl_live_apikey_... or pdl_sdbx_apikey_...
# PADDLE_ENVIRONMENT=sandbox  # or production
# NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_... or live_... (used by Paddle.js in the billing UI)
# NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox  # or production
# PADDLE_WEBHOOK_SECRET=pdl_ntfset_... (secret from your webhook notification destination)
#
# Price IDs — create matching recurring products in Paddle Catalog, then paste each pri_... here.
# Tiers (monthly list; annual -20% is handled in Paddle or as separate annual prices if you offer both):
#   Solo         $39/mo   — up to 5 clients
#   Pro          $99/mo   — up to 15 clients   (PADDLE_PRICE_STARTER — internal id "starter")
#   Business    $199/mo   — up to 35 clients   (PADDLE_PRICE_GROWTH)
#   Scale       $299/mo   — up to 50 clients
#   White-label $499/mo   — up to 75 clients
#   Enterprise  custom     — unlimited (optional pri_ if you bill Enterprise through Paddle)
#   Pilot       partner    — optional separate price for pilot program
#
# PADDLE_PRICE_SOLO=pri_...
# PADDLE_PRICE_PILOT=pri_...
# PADDLE_PRICE_STARTER=pri_...
# PADDLE_PRICE_GROWTH=pri_...
# PADDLE_PRICE_SCALE=pri_...
# PADDLE_PRICE_WHITELABEL=pri_...
# PADDLE_PRICE_ENTERPRISE=pri_...

# ── Resend (Phase 2 — email alerts) ────────────────────────────────────────────
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=alerts@vantirs.app
# NEXT_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/0

# ── Slack (Phase 3 — real-time alerts) ────────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Upstash Redis (Phase 3 — job queues / rate limiting) ───────────────────────
# UPSTASH_REDIS_URL=https://...
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...

# Analytics & CRO
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_HOTJAR_ID=
NEXT_PUBLIC_CRISP_ID=
